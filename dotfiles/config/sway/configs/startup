# startup

# waybar
exec $waybarS

# notification
exec $makoS

# restore saved brightness
exec light -I

# swayOSD
exec swayosd-server

# autotiling
exec_always autotiling

# polkit
exec /usr/lib/xfce-polkit/xfce-polkit

# displays
exec kanshi

# idle
exec swayidle -w \
        timeout 300 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
        timeout 600 'systemctl sleep' \
        before-sleep '$lockS -f'
