# Adovaz's config for sway

### Variables

set $mod Mod4
set $alt Mod1
set $ctrl ctrl

set $left h
set $down j
set $up k
set $right l

# terminal emulator
set $term kitty
# VSCode
set $codium code
# browser
set $browser firefox
# file manager
set $filemgr thunar

# scripts
set $lockS swaylock
set $screenshotS ~/.config/sway/scripts/screenshot.sh
set $colorpickerS exec wl-color-picker

set $drunS ~/.config/sway//scripts/menu.sh drun
set $runS ~/.config/sway/scripts/menu.sh run
set $pmenuS ~/.config/rofi/launchers/pmenu.sh

set $waybarS waybar -c ~/.config/waybar/config.jsonc -s ~/.config/waybar/style.css
set $makoS mako -c ~/.config/mako/config

set $brightnessdownS exec swayosd-client --brightness lower
set $brightnessupS exec swayosd-client --brightness raise

set $volumemuteS exec swayosd-client --output-volume mute-toggle
set $volumedownS exec swayosd-client --output-volume lower
set $volumeupS exec swayosd-client --output-volume raise  
set $micmuteS ~/.config/sway/togglemic.sh

set $togglewifiS ~/.config/waybar/togglewifi.shs

# includes

include ~/.config/sway/configs/input

include ~/.config/sway/configs/output

include ~/.config/sway/configs/startup

include ~/.config/sway/configs/keybinds

include ~/.config/sway/configs/theme